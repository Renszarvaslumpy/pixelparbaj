            <div class="game-scene-finished"></div>
            <div class="game-scene-finished"></div>
            <div class="game-scene-finished"></div>
            <div class="game-scene-finished"></div>
            <div class="game-scene-finished"></div>
            <div class="game-scene-finished"></div>
