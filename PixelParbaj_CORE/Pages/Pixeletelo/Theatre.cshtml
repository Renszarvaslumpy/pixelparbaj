@page
@model PixelParbaj_CORE.Pages.Pixeletelo.TheatreModel
@{
    ViewData["Title"] = "Játék";
    int count = 0;
}

<div class="theatre-epilogue hidden">
    <div>
        <div>A játék véget ért! A győztes pedig ... </div>
    </div>
</div>

<div class="movies-list">

    <div id="game-result">

        <div class="game-scene"></div>
        <div class="game-scene"></div>
        <div class="game-scene"></div>
        <div class="game-scene"></div>
        <div class="game-scene"></div>
        <div class="game-scene"></div>
        <div class="game-scene"></div>
        <div class="game-scene"></div>

    </div>

    <div class="countdown-wrapper">
        <div id="countdown">20.00</div>
    </div>

    <div class="scene-progress hidden">
        <div class="scene-progress-header">Lejárt az idő!</div>

        <div class="result-list">
            <div class="result-list-header">Eredmények:</div>
            <div class="scene-results"></div>
        </div>
    </div>

    <div class="posters">
        @foreach (var movie in Model.SelectedMovies)
        {
            List<string> pixelated = movie.GetPixelatedPosters();
            <div class="movies-list-poster hidden" movie-id="@movie.Id" movie-imdb="@movie.Imdb">

                <div class="movies-list-poster-image" style="background-image:url('data:image/jpg;base64,@movie.GetPoster()')">

                    @for (int i = 0; i < pixelated.Count; i++)
                    {
                        <div style="background-image:url('data:image/jpg;base64,@pixelated[i]')"></div>
                    }

                </div>

            </div>
            count++;
        }
    </div>

    <div id="game-finished">
        <div id="game-finished-results">
            
        </div>
    </div>

    <div>
        <div id="back-to" class="generic-button hidden"><a href="/Room?RoomHash=@Model.RoomHash">Vissza a Párbajra / Partiba</a></div>
    </div>

</div>

<script type="text/javascript">

    var counter = 0;
    var GameResults = [];
    var Movies = [];

    function Game(id, time) {
        this.id = id;
        this.time = time;
    }

    function now() {
        return window.performance ? window.performance.now() : Date.now();
    }

    var count = 20000;
    var delay = 20; //20 ms. This will be only indicative. There's no guarantee the browswer will call the function after exactly this time

    var countAction = 10000;
    var delayAction = 20;

    var initTick = 0;
    var initTickAction = 0;

    function tick() {

        var timerElement = document.getElementById("countdown");
        var remaining = (count - (now() - initTick)) / 1000;
        remaining = remaining >= 0 ? remaining : 0;

        var secs = remaining.toFixed(2);

        PixelNext(secs);

        timerElement.innerHTML = secs;
        if (remaining) {

            setTimeout(tick, delay);

        } else {

            UpdateProgress().then(function () {

                DisplayProgress().then(function (r) {

                    ShowProgress(r);

                    setTimeout(function () {

                        HideProgress();

                        StartScene().then(function () {
                            Next();
                        });
                        
                    }, 10000);

                });

            });
        }
    }

    var remainingAction;
    function tickAction() {
        var timerElement = document.getElementById("action-countdown");
        var remaining = (countAction - (now() - initTickAction)) / 1000;
        remaining = remaining >= 0 ? remaining : 0;
        var secs = remaining.toFixed(2);
        remainingAction = remaining.toFixed(2);
        timerElement.innerHTML = secs;

        if (pausedAction) {
            return;

            let add = 10000 - (secs * 1000);
            console.log(count);
            console.log(add);
            count += 10000 - (secs * 1000);
            console.log(count);
        }

        if (remaining) {
            setTimeout(tickAction, delayAction);
        } else {
            count += 10000;
            tick();
        }
    }

    initTick = now();
    setTimeout(tick, delay);

    $(document).ready(function () {

        StartGame().then(function () { 
        
            Start();
            window.onbeforeunload = function (e) {
                return 'Biztos ki akarsz lépni a játékból? Utána már nem lesz lehetőséged folytatni!';
            };

        });
        
    })

    function Start() {

        $(".movies-list-poster").first().removeClass("hidden");
        currentMovie = $(".movies-list-poster").first().attr("movie-id");
    }

    var a, b, c, d, e, f, g, h, i;
    function PixelNext(secs) {

        console.log("PixelNext");

        if (secs < 18 && secs > 16) {
            if (a) {
                return;
            }
            a = true;
            $(".movies-list-poster").not(".hidden").children().children().last().remove();
        }
        if (secs < 16 && secs > 14) {
            if (b) {
                return;
            }
            b = true;
            $(".movies-list-poster").not(".hidden").children().children().last().remove();
        }
        if (secs < 14 && secs > 12) {
            if (c) {
                return;
            }
            c = true;
            $(".movies-list-poster").not(".hidden").children().children().last().remove();
        }
        if (secs < 12 && secs > 10) {
            if (d) {
                return;
            }
            d = true;
            $(".movies-list-poster").not(".hidden").children().children().last().remove();
        }
        if (secs < 10 && secs > 8) {
            if (e) {
                return;
            }
            e = true;
            $(".movies-list-poster").not(".hidden").children().children().last().remove();
        }
        if (secs < 8 && secs > 6) {
            if (f) {
                return;
            }
            f = true;
            $(".movies-list-poster").not(".hidden").children().children().last().remove();
        }
        if (secs < 6 && secs > 4) {
            if (g) {
                return;
            }
            g = true;
            $(".movies-list-poster").not(".hidden").children().children().last().remove();
        }
        if (secs < 4 && secs > 2) {
            if (h) {
                return;
            }
            h = true;
            $(".movies-list-poster").not(".hidden").children().children().last().remove();
        }
        if (secs < 2) {
            if (i) {
                return;
            }
            i = true;
            $(".movies-list-poster").not(".hidden").children().children().last().remove();
        }

    }

    function Next() {

        console.log("Next");

        a = false;
        b = false;
        c = false;
        d = false;
        e = false;
        f = false;
        g = false;
        h = false;
        i = false;

        var id = $(".movies-list-poster").not(".hidden").attr("movie-id");
        var time = $("#countdown").text();
        var game = new Game(id, time)
        GameResults.push(game);

        if (Number(time) > 16) {
            $(".game-scene").eq(counter).addClass("scene-5");
        } else if (Number(time) <= 16 && Number(time) > 12) {
            $(".game-scene").eq(counter).addClass("scene-4");
        } else if (Number(time) <= 12 && Number(time) > 8) {
            $(".game-scene").eq(counter).addClass("scene-3");
        } else if (Number(time) <= 8 && Number(time) > 4) {
            $(".game-scene").eq(counter).addClass("scene-2");
        } else {
            $(".game-scene").eq(counter).addClass("scene-1");
        }

        counter++;

        var current = $(".movies-list-poster").not(".hidden");
        $(current).addClass("hidden");

        if ($(current).next().length > 0) {
            $(current).next().removeClass("hidden");

            count = 20000;
            initTick = now();
            setTimeout(tick, delay);

        } else {
            End();
        }

    }

    function End() {

        window.onbeforeunload = null;
        console.log("End");

        $(".theatre-epilogue").removeClass("hidden");

        setTimeout(function () {
            $(".theatre-epilogue").addClass("hidden");
            DisplayFinish().then(function (r) {

                ShowFinish(r);

                $("#game-finished").show();
                $("#game-finished").addClass("magictime").removeClass("puffOut");
                $("#game-finished").addClass("magictime").addClass("puffIn");
                $(".movie-input-wrapper").addClass("hidden");
                $(".posters").addClass("hidden");
                $(".countdown-wrapper").addClass("hidden");

            });
        }, 5000);

        /*if (IsRoom()) {
            $("#back-to").removeClass("hidden");
        }*/

    }

    function IsRoom() {
        const queryString = window.location.search;
        const urlParams = new URLSearchParams(queryString);
        const room = urlParams.get('RoomHash')
        if (room) {
            return true;
        }
        return false;
    }

    const DisplayProgress = () => new Promise((myResolve, myReject) => {
        
        console.log("DisplayProgress");

        return $.ajax({
            type: "GET",
            url: "/api/Pixeletelo/GetProgress",
            cache: false,
            data: {
                RoomHash: "@Model.RoomHash",
                Scene: counter
            },
            success: function (r) {
                
                console.log("DisplayProgress Success");
                myResolve(r);

            },
            error: function (r) {

                console.log("DisplayProgress Error");
                myReject();

            }
        });

        console.log("DisplayProgress Fall");

    });

    function ShowProgress(r) {

        console.log("ShowProgress");

        $(".posters").addClass("hidden");
        $(".countdown-wrapper").addClass("hidden");
        $(".scene-progress").removeClass("hidden");

        console.log(r);

        if (r != undefined) {

            $(".scene-progress > div").remove();

            for (var i = 0; i < r.scenePlayers.length; i++) {

                let time = 0;
                switch (counter) {
                    case 0:
                        time = r.sceneProgress[i].time1;
                        break;
                    case 1:
                        time = r.sceneProgress[i].time2;
                        break;
                    case 2:
                        time = r.sceneProgress[i].time3;
                        break;
                    case 3:
                        time = r.sceneProgress[i].time4;
                        break;
                    case 4:
                        time = r.sceneProgress[i].time5;
                        break;
                    case 5:
                        time = r.sceneProgress[i].time6;
                        break;
                    case 6:
                        time = r.sceneProgress[i].time7;
                        break;
                    case 7:
                        time = r.sceneProgress[i].time8;
                        break;
                }

                time = 20.0 - time;

                $(".scene-progress").append("<div><div class=\"main-avatar\" style=\"background-image:url('data:image/png;base64," + r.scenePlayers[i].avatar + "')\"></div><div>" + r.scenePlayers[i].name + "</div><div class=\"date-tag scene-" + GetHighlightOne(time) + " \">" + time + "s</div></div>");
            }
        }
    }

    function HideProgress(){

        console.log("HideProgress");

        $(".scene-progress").addClass("hidden");
        $(".posters").removeClass("hidden");
        $(".countdown-wrapper").removeClass("hidden");

    }

    const UpdateProgress = () => new Promise((myResolve, myReject) => {

        return $.ajax({
            type: "GET",
            url: "/api/Pixeletelo/Update",
            cache: false,
            data: {
                RoomHash: "@Model.RoomHash",
                Movie: counter
            },
            success: function () {
                myResolve();
            },
            error: function () {
                myReject();
            }
        });

    });

    const StartGame = () => new Promise((myResolve, myReject) => {

        return $.ajax({
            type: "GET",
            url: "/api/Pixeletelo/Start",
            cache: false,
            data: {
                RoomHash: "@Model.RoomHash"
            },
            success: function () {
                myResolve();
            },
            error: function () {
                myReject();
            }
        });

    });

    const StartScene = () => new Promise((myResolve, myReject) => {

        return $.ajax({
            type: "GET",
            url: "/api/Pixeletelo/StartScene",
            cache: false,
            data: {
                RoomHash: "@Model.RoomHash",
                Movie: counter
            },
            success: function () {
                myResolve();
            },
            error: function () {
                myReject();
            }
        });

    });



    const DisplayFinish = () => new Promise((myResolve, myReject) => {

        console.log("DisplayFinish");

        return $.ajax({
            type: "GET",
            url: "/api/Pixeletelo/GetResults",
            cache: false,
            data: {
                RoomHash: "@Model.RoomHash"
            },
            success: function (r) {

                console.log("DisplayFinish Success");
                myResolve(r);

            },
            error: function (r) {

                console.log("DisplayFinish Error");
                myReject();

            }
        });

        console.log("DisplayFinish Fall");

    });

    function ShowFinish(r) {

        console.log("ShowFinish");

        if (r != undefined) {
            for (var i = 0; i < r.finishedGames.length; i++) 
            {
                $("#game-finished-results").append("<div><div class=\"main-avatar\" style=\"background-image:url('data:image/png;base64," + r.finishedPlayers[i].avatar + "')\"></div><div>" + r.finishedPlayers[i].name + "</div><div class=\"date-tag scene-" + GetHighlight(r.finishedTime[i]) + "\">" + r.finishedTime[i] + "s</div></div>")
            }

        }
    }

    function GetHighlightOne(time) {
        if (time > 14) {
            return 1;
        }
        if (time > 12) {
            return 2;
        }
        if (time > 10) {
            return 3;
        }
        if (time > 8) {
            return 4;
        }
        else {
            return 5;
        }
    }

    function GetHighlight(time) {

        if (time > 140) {
            return 1;
        }
        if (time > 120) {
            return 2;
        }
        if (time > 100) {
            return 3;
        }
        if (time > 80) {
            return 4;
        }
        else {
            return 5;
        }

    }





</script>

@if (string.IsNullOrEmpty(Model.UserEmail))
{
    <script>

        // cookie for 3 plays

        $(document).ready(function () {

            var count = getCookie("games");

            console.log(count);

            if (count === undefined || count == "") {
                PlayCount();
            } else {
                if (Number(count) >= 3) {
                    // cannot play anymore
                    GameOver();
                }
            }

        })

        function GameOver() {
            window.onbeforeunload = null;
            window.alert("Sajnos elérted a maximális játékok számát. Ha többet szeretnél játszani, regisztrálj be!");
            location.href = "/Login";
        }

        function PlayCount() {

            var count = getCookie("games");
            if (count === undefined || count == "") {
                document.cookie = "games=" + 1;
            } else {
                document.cookie = "games=" + Number(count) + 1;
            }

        }

        function getCookie(cname) {
            let name = cname + "=";
            let decodedCookie = decodeURIComponent(document.cookie);
            let ca = decodedCookie.split(';');
            for (let i = 0; i < ca.length; i++) {
                let c = ca[i];
                while (c.charAt(0) == ' ') {
                    c = c.substring(1);
                }
                if (c.indexOf(name) == 0) {
                    return c.substring(name.length, c.length);
                }
            }
            return "";
        }

    </script>
}
